#!/bin/bash
#
# FY-4B GitHub 推送脚本 (统一版)
# 用法: ./push [--config|--help] [提交信息]
#
# 示例:
#   ./push                    # 一键推送（自动生成提交信息）
#   ./push "修复了bug"         # 一键推送（自定义提交信息）
#   ./push --config           # 配置 GitHub Token
#   ./push --help             # 显示帮助
#

set -e

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 配置
CONFIG_FILE="$HOME/.github_push_fy4b"
REPO_URL="github.com/billy31/fy-4b-superResultion.git"

# ==================== 功能函数 ====================

# 显示帮助
show_help() {
    cat << EOF
${BLUE}=============================================${NC}
${BLUE}  FY-4B Super Resolution - GitHub 推送工具  ${NC}
${BLUE}=============================================${NC}

${GREEN}用法:${NC}
  ./push                      一键推送所有变更
  ./push "提交说明"            使用自定义提交信息推送
  ./push --config  或  -c     配置 GitHub Token
  ./push --help    或  -h     显示此帮助

${GREEN}首次使用:${NC}
  1. 运行: ./push --config
  2. 输入 GitHub 用户名和 Token
  3. 之后直接用 ./push 推送

${GREEN}Token 获取:${NC}
  https://github.com/settings/tokens/new
  勾选 "repo" 权限即可

${GREEN}当前仓库:${NC}
  https://$REPO_URL

EOF
}

# 配置向导
setup_config() {
    echo -e "${BLUE}=============================================${NC}"
    echo -e "${BLUE}         GitHub 配置向导                    ${NC}"
    echo -e "${BLUE}=============================================${NC}"
    echo ""
    
    # 用户名
    read -p "GitHub 用户名 [billy31]: " username
    username=${username:-billy31}
    
    # Token
    echo ""
    echo -e "${YELLOW}请访问: https://github.com/settings/tokens/new${NC}"
    echo -e "${YELLOW}生成 Token，勾选 'repo' 权限${NC}"
    echo ""
    read -s -p "输入 GitHub Token: " token
    echo ""
    
    # 验证输入
    if [[ -z "$token" ]]; then
        echo -e "${RED}✗ Token 不能为空${NC}"
        exit 1
    fi
    
    # 保存配置
    cat > "$CONFIG_FILE" << EOF
GITHUB_USERNAME=$username
GITHUB_TOKEN=$token
EOF
    chmod 600 "$CONFIG_FILE"
    
    echo ""
    echo -e "${GREEN}✓ 配置已保存${NC}"
    echo -e "${GREEN}✓ 现在可以运行: ./push${NC}"
    echo ""
}

# 加载配置
load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo -e "${RED}✗ 未配置 GitHub Token${NC}"
        echo ""
        echo "请运行: ./push --config"
        exit 1
    fi
    source "$CONFIG_FILE"
    
    if [[ -z "$GITHUB_USERNAME" ]] || [[ -z "$GITHUB_TOKEN" ]]; then
        echo -e "${RED}✗ 配置损坏，请重新配置${NC}"
        setup_config
    fi
}

# 生成提交信息
generate_msg() {
    local custom="$1"
    if [[ -n "$custom" ]]; then
        echo "$custom"
        return
    fi
    
    # 统计变更
    local file_count=$(git diff --name-only 2>/dev/null | wc -l)
    local date_str=$(date '+%m-%d %H:%M')
    
    # 检测类型
    if git diff --name-only | grep -qE '\.(py|sh)$'; then
        echo "[$date_str] 更新代码 ($file_count 个文件)"
    elif git diff --name-only | grep -qE '\.md$'; then
        echo "[$date_str] 更新文档 ($file_count 个文件)"
    else
        echo "[$date_str] 更新项目 ($file_count 个文件)"
    fi
}

# 执行推送
do_push() {
    load_config
    
    # 检查 git 仓库
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        echo -e "${RED}✗ 当前目录不是 Git 仓库${NC}"
        exit 1
    fi
    
    # 检查变更
    if git diff --quiet && git diff --cached --quiet; then
        echo -e "${YELLOW}⚠ 没有变更需要推送${NC}"
        exit 0
    fi
    
    # 显示变更
    echo -e "${BLUE}待推送文件:${NC}"
    git status --short
    echo ""
    
    # 生成提交信息
    local msg=$(generate_msg "$1")
    echo -e "提交信息: ${YELLOW}$msg${NC}"
    echo ""
    
    # 确认
    read -p "确认推送? [Y/n]: " confirm
    if [[ "$confirm" =~ ^[Nn]$ ]]; then
        read -p "输入新提交信息: " new_msg
        msg="${new_msg:-$msg}"
    fi
    
    # 提交
    echo ""
    echo -e "${BLUE}正在提交...${NC}"
    git add -A
    git commit -m "$msg" || true
    
    # 推送
    echo -e "${BLUE}正在推送到 GitHub...${NC}"
    git remote remove origin 2>/dev/null || true
    git remote add origin "https://$GITHUB_USERNAME:$GITHUB_TOKEN@$REPO_URL" 2>/dev/null || true
    git branch -M main
    
    if git push -u origin main; then
        echo ""
        echo -e "${GREEN}✓ 推送成功!${NC}"
        echo -e "${BLUE}https://$REPO_URL${NC}"
    else
        echo ""
        echo -e "${RED}✗ 推送失败${NC}"
        echo "请检查:"
        echo "  1. Token 是否过期 (https://github.com/settings/tokens)"
        echo "  2. 网络连接"
        echo "  3. 是否有仓库写入权限"
        exit 1
    fi
}

# ==================== 主入口 ====================

case "$1" in
    --config|-c)
        setup_config
        ;;
    --help|-h)
        show_help
        ;;
    *)
        do_push "$1"
        ;;
esac
